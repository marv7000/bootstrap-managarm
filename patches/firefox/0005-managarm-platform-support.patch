 #define DRM_IOCTL_NR(n)		_IOC_NR(n)
 #define DRM_IOC_VOID		_IOC_NONE
--- a/toolkit/components/backgroundhangmonitor/ThreadStackHelper.cpp
+++ b/toolkit/components/backgroundhangmonitor/ThreadStackHelper.cpp
@@ -37,7 +37,9 @@
 #ifdef XP_LINUX
 #  include <ucontext.h>
 #  include <unistd.h>
-#  include <sys/syscall.h>
+#  ifndef __managarm__
+#    include <sys/syscall.h>
+#  endif
 #endif
 
 #ifdef __GNUC__
--- a/toolkit/components/backgroundhangmonitor/ThreadStackHelper.h
+++ b/toolkit/components/backgroundhangmonitor/ThreadStackHelper.h
@@ -38,6 +38,10 @@
 #  undef MOZ_THREADSTACKHELPER_NATIVE_STACK
 #endif
 
+#if defined(__managarm__)
+#  undef MOZ_THREADSTACKHELPER_NATIVE_STACK
+#endif
+
 namespace mozilla {
 
 /**
--- a/tools/profiler/core/ProfilerUtils.cpp
+++ b/tools/profiler/core/ProfilerUtils.cpp
@@ -59,6 +59,12 @@
   return ProfilerThreadId::FromNativeId(gettid());
 }
 
+#  elif defined(__managarm__)
+
+ProfilerThreadId profiler_current_thread_id() {
+  return ProfilerThreadId::FromNativeId(gettid());
+}
+
 // ------------------------------------------------------- Linux
 #  elif defined(XP_LINUX)
 
--- a/xpcom/io/nsLocalFileUnix.h
+++ b/xpcom/io/nsLocalFileUnix.h
@@ -28,7 +28,8 @@
