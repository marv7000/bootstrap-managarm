From 6097b31d7cdc731c56c2dffe93673d0c8ce2e6df Mon Sep 17 00:00:00 2001
From: Marvin Friedrich <contact@marvinf.com>
Date: Thu, 4 Jun 2026 11:46:21 +0200
Subject: [PATCH 5/5] managarm: add socket constants and multi-message bindings

Add SO_TYPE/SO_SNDBUF/SO_RCVBUF/SO_KEEPALIVE/SO_OOBINLINE/SOCK_SEQPACKET,
the mmsghdr and in6_pktinfo structs, and recvmmsg/sendmmsg, which Firefox's
networking crates (socket2, quinn-udp) require. Values match mlibc's headers.
---
 src/unix/linux_like/managarm/mod.rs | 28 ++++++++++++++++++++++++++++
 1 file changed, 28 insertions(+)

diff --git a/src/unix/linux_like/managarm/mod.rs b/src/unix/linux_like/managarm/mod.rs
index 162b1ab..152f3a7 100644
--- a/src/unix/linux_like/managarm/mod.rs
+++ b/src/unix/linux_like/managarm/mod.rs
@@ -197,6 +197,14 @@ s! {
         pub cmsg_level: c_int,
         pub cmsg_type: c_int,
     }
+    pub struct mmsghdr {
+        pub msg_hdr: crate::msghdr,
+        pub msg_len: c_uint,
+    }
+    pub struct in6_pktinfo {
+        pub ipi6_addr: crate::in6_addr,
+        pub ipi6_ifindex: c_uint,
+    }
     pub struct sigset_t {
         pub __sig: [c_ulong; 16],
     }
@@ -663,10 +671,16 @@ pub const FALLOC_FL_KEEP_SIZE: c_int = 1;
 pub const FALLOC_FL_PUNCH_HOLE: c_int = 2;
 pub const SOCK_STREAM: c_int = 1;
 pub const SOCK_DGRAM: c_int = 2;
+pub const SOCK_SEQPACKET: c_int = 5;
 pub const SOCK_NONBLOCK: c_int = 0o4000;
 pub const SO_REUSEADDR: c_int = 2;
+pub const SO_TYPE: c_int = 3;
 pub const SO_ERROR: c_int = 4;
 pub const SO_BROADCAST: c_int = 6;
+pub const SO_SNDBUF: c_int = 7;
+pub const SO_RCVBUF: c_int = 8;
+pub const SO_KEEPALIVE: c_int = 9;
+pub const SO_OOBINLINE: c_int = 10;
 pub const SO_LINGER: c_int = 13;
 pub const SO_RCVTIMEO: c_int = 20;
 pub const SO_SNDTIMEO: c_int = 21;
@@ -866,6 +880,20 @@ pub const TCSAFLUSH: c_int = 2;
 pub const TIOCGWINSZ: crate::Ioctl = 0x5413;
 pub const TIOCSWINSZ: crate::Ioctl = 0x5414;
 extern "C" {
+    pub fn recvmmsg(
+        sockfd: c_int,
+        msgvec: *mut crate::mmsghdr,
+        vlen: c_uint,
+        flags: c_int,
+        timeout: *mut crate::timespec,
+    ) -> c_int;
+    pub fn sendmmsg(
+        sockfd: c_int,
+        msgvec: *mut crate::mmsghdr,
+        vlen: c_uint,
+        flags: c_int,
+    ) -> c_int;
+
     #[link_name = "__gnu_strerror_r"]
     pub fn strerror_r(errnum: c_int, buf: *mut c_char, buflen: size_t) -> c_int;
 
-- 
