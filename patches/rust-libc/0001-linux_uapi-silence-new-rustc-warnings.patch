From 5bd577424a571bd465b7d1b9daa51081ab45aff9 Mon Sep 17 00:00:00 2001
From: no92 <no92.mail@gmail.com>
Date: Thu, 4 Jun 2026 11:13:57 +0200
Subject: [PATCH 1/5] linux_uapi: silence new rustc warnings

---
 src/new/linux_uapi/linux/can/j1939.rs | 2 +-
 src/new/linux_uapi/linux/can/raw.rs   | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/new/linux_uapi/linux/can/j1939.rs b/src/new/linux_uapi/linux/can/j1939.rs
index fdf425c..988042b 100644
--- a/src/new/linux_uapi/linux/can/j1939.rs
+++ b/src/new/linux_uapi/linux/can/j1939.rs
@@ -1,6 +1,6 @@
 //! `linux/can/j1939.h`
 
-pub use crate::linux::can::*;
+pub(crate) use crate::linux::can::*;
 
 pub const J1939_MAX_UNICAST_ADDR: c_uchar = 0xfd;
 pub const J1939_IDLE_ADDR: c_uchar = 0xfe;
diff --git a/src/new/linux_uapi/linux/can/raw.rs b/src/new/linux_uapi/linux/can/raw.rs
index 470334b..a738d98 100644
--- a/src/new/linux_uapi/linux/can/raw.rs
+++ b/src/new/linux_uapi/linux/can/raw.rs
@@ -1,6 +1,6 @@
 //! Header: `linux/can/raw.h`
 
-pub use crate::linux::can::*;
+pub(crate) use crate::linux::can::*;
 
 pub const SOL_CAN_RAW: c_int = SOL_CAN_BASE + CAN_RAW;
 pub const CAN_RAW_FILTER_MAX: c_int = 512;
